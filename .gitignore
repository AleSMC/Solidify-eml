# ======================================================================
# SOLIDIFY-EML: .gitignore
# ======================================================================

# ----------------------------------------------------------------------
# 1. LEAN 4 & LAKE (Verificación Formal)
# ----------------------------------------------------------------------
.lake/
build/
*.olean
*.ilean
*.c
*.o

# ----------------------------------------------------------------------
# 2. SOLIDITY (Foundry / Hardhat - Banco de Pruebas)
# ----------------------------------------------------------------------
# Foundry
out/
cache/
broadcast/
cache_forge/

# Hardhat / Node
node_modules/
artifacts/
typechain/
typechain-types/
coverage/
coverage.json

# ----------------------------------------------------------------------
# 3. PYTHON (Parser AST e Intuición Artificial)
# ----------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class
.venv/
venv/
ENV/
env/
.tox/
.pytest_cache/

# ----------------------------------------------------------------------
# 4. SEGURIDAD Y VARIABLES DE ENTORNO (Crítico para APIs)
# ----------------------------------------------------------------------
.env
.env.*
*.pem
secrets.json

# ----------------------------------------------------------------------
# 5. EDITORES Y SISTEMA OPERATIVO
# ----------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace

# IntelliJ / PyCharm
.idea/
*.iml

# OS (Mac / Windows)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/
